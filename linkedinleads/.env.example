## LinkedIn Scraper — Backend FastAPI
## Copia este fichero a `.env` y rellena los valores sensibles.

# Puerto del servidor FastAPI
LINKEDIN_API_PORT=8003

# ---------------------------
# Anti-ban / limites de scraping
# ---------------------------
MAX_CONTACTS_PER_RUN=20
MAX_CONTACTS_PER_DAY=60
MAX_CONTACTS_CAP=50
SCRAPE_WINDOW_START=8
SCRAPE_WINDOW_END=21
MIN_HOURS_BETWEEN_RUNS=0
COOLDOWN_HOURS_AFTER_429=48
SCHEDULED_RANDOM_DELAY_MINUTES=25
CONTACT_REFRESH_DAYS=30

# ---------------------------
# Scraping (Selenium)
# ---------------------------
BROWSER_PROFILE_WAIT=15
SLEEP_BETWEEN_CONNECTIONS=6
HEADLESS=true
CHROME_BINARY=

# ---------------------------
# Notificaciones Telegram (opcional)
# ---------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------
# Cifrado de credenciales (re-login automatico)
# ---------------------------
# Genera una clave nueva:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_KEY=

# ---------------------------
# Base de datos SQLite (opcional)
# ---------------------------
# Por defecto: data/contacts.db
DB_PATH=

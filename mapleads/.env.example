WEBSHARE_PROXY_PORT=80

# ─── Base de datos ──────────────────────────────────────────────────────────
DB_PATH=./data/mapleads.db

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ─── Límites por proxy individual ───────────────────────────────────────────
# Requests seguros antes de que el proxy entre en cooldown
MAX_REQUESTS_PER_PROXY_BEFORE_COOLDOWN=40
# Segundos de descanso del proxy tras alcanzar el límite (6 minutos)
PROXY_COOLDOWN_SECONDS=360

# ─── Concurrencia ───────────────────────────────────────────────────────────
# Max requests simultáneas (todas las corrutinas combinadas)
MAX_CONCURRENT_REQUESTS=15
# Delay entre requests (segundos, aleatorio entre min y max)
REQUEST_DELAY_MIN_SECONDS=0.5
REQUEST_DELAY_MAX_SECONDS=1.5

# ─── Circuit breaker ────────────────────────────────────────────────────────
# Si el error rate de un proxy supera este % → cooldown largo inmediato
ERROR_RATE_THRESHOLD=0.30
# Duración del cooldown por circuit breaker (10 minutos)
HIGH_ERROR_COOLDOWN_SECONDS=600

# ─── Límite duro diario ─────────────────────────────────────────────────────
# Techo absoluto de requests por día para proteger todos los proxies
MAX_REQUESTS_PER_DAY=10000

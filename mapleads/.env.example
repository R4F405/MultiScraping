WEBSHARE_PROXY_PASS=your_webshare_pass
WEBSHARE_PROXY_HOST=proxy.webshare.io
WEBSHARE_PROXY_PORT=80

# ─── Lista de proxies estáticos (opcional) ──────────────────────────────────

# ─── Base de datos ──────────────────────────────────────────────────────────
DB_PATH=./data/mapleads.db

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Límites por proxy individual ───────────────────────────────────────────
MAX_REQUESTS_PER_PROXY_BEFORE_COOLDOWN=30
PROXY_COOLDOWN_SECONDS=480

# ─── Concurrencia ───────────────────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=6
REQUEST_DELAY_MIN_SECONDS=1.0
REQUEST_DELAY_MAX_SECONDS=2.5

# ─── Circuit breaker ────────────────────────────────────────────────────────
ERROR_RATE_THRESHOLD=0.20
HIGH_ERROR_COOLDOWN_SECONDS=900

# ─── Límite duro diario ─────────────────────────────────────────────────────
MAX_REQUESTS_PER_DAY=6000

# ─── Seguridad API (recomendado en producción) ─────────────────────────────
API_KEY=

# ─── Dedupe window (days): skip businesses seen recently ────────────────────
DEDUPE_DAYS=30
# ─── Email desde web ────────────────────────────────────────────────────────
# Si MX no existe pero el dominio tiene A, considerar válido (menos estricto).
EMAIL_DNS_ACCEPT_A=0
# Si 1, Playwright en home si curl no encuentra emails (pip install playwright && playwright install chromium).
EMAIL_SCRAPER_USE_PLAYWRIGHT=0

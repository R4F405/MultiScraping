DB_PATH=./data/tiktokleads.db
LOG_LEVEL=INFO
PORT=8004

# Browser
TIKTOK_HEADLESS=true
# One proxy or comma-separated pool for rotation
TIKTOK_PROXY_URL=
TIKTOK_SESSION_STATE_PATH=./data/tiktok_session_state.json
TIKTOK_WARMUP_ENABLED=true
TIKTOK_WARMUP_URL=https://www.tiktok.com/

# Rate limiting
MAX_REQ_HOUR=40
MAX_DAILY=200
DELAY_MIN=3.0
DELAY_MAX=8.0
MAX_CONCURRENT_WORKERS=1

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=5.0
RETRY_MAX_DELAY=60.0

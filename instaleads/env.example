# Server
PORT=8002

# Database
DB_PATH=./data/instaleads.db
SESSION_FILE=./data/instaleads.session

# Logging
LOG_LEVEL=INFO

# Campaign limits
MAX_UNAUTH_DAILY=400
MAX_AUTH_DAILY=1200
MAX_AUTH_HOURLY=250
MAX_CONCURRENT_UNAUTH=4
MAX_CONCURRENT_AUTH=8
DELAY_UNAUTH_MIN=1.4
DELAY_UNAUTH_MAX=3.4
DELAY_AUTH_MIN=0.8
DELAY_AUTH_MAX=2.2
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.5
RETRY_MAX_DELAY=15

# Discovery (provider-free: only internal/login local providers)
DISCOVERY_PROVIDER=internal
DISCOVERY_MIN_COVERAGE_RATIO=0.45
DISCOVERY_LOGIN_ESCALATION_RATIO=0.35

# Enrichment
ENRICHMENT_HTTP_TIMEOUT_SEC=8
ENRICHMENT_FOLLOW_CONTACT_PAGES=1
ENRICHMENT_MAX_SUBPAGES=3

# Proxy
IG_PROXY_URL=
PROXY_LIST=
PROXY_OPEN_THRESHOLD=35
PROXY_HALF_OPEN_THRESHOLD=60
PROXY_COOLDOWN_SECONDS=180

# Feature flags
LIVE_SMOKE_ENABLED=0

# InstaLeads Backend Configuration
# Copy this file to .env and fill in your values

# Database
DB_PATH=./data/instaleads.db

# Session encryption (leave empty to auto-generate on first run)
SESSION_FILE=./data/session.json
SESSION_KEY=

# Logging
LOG_LEVEL=INFO

# Waterfall enrichment (website fetches, separado de límites IG)
ENRICHMENT_MAX_FETCHES_PER_HOUR=60
ENRICHMENT_HTTP_TIMEOUT_SEC=10

# Auto-resume (Mode B)
FOLLOWERS_AUTO_RESUME_ENABLED=1
FOLLOWERS_MAX_RESUMES_PER_DAY=48

# Rate limits — unauthenticated (Mode A: Dorking)
MAX_UNAUTH_DAILY=150
DELAY_UNAUTH_MIN=4
DELAY_UNAUTH_MAX=9
MAX_CONCURRENT_UNAUTH=3

# Rate limits — authenticated (Mode B: Followers)
MAX_AUTH_DAILY=80
MAX_AUTH_HOURLY=20
DELAY_AUTH_MIN=4
DELAY_AUTH_MAX=10

# Server
PORT=8002

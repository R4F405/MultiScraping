# URL del backend MapLeads (Google Maps scraper)
MAPLEADS_API_URL=http://localhost:8001

# URL del backend InstaLeads (Instagram scraper)
INSTALEADS_API_URL=http://localhost:8002


# URL del backend LinkedIn
LINKEDINLEADS_API_URL=http://localhost:8003

# Si MapLeads tiene API_KEY en .env, pon la misma clave aquí (cabecera X-API-Key)
MAPLEADS_API_KEY=

# Puerto del frontend
PORT=8081

# ── Autenticación ─────────────────────────────────────────────────────────────

# Clave secreta para firmar las cookies de sesión. OBLIGATORIO en producción.
# Genera una: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-production

# Duración de la sesión en segundos (28800 = 8 horas)
SESSION_MAX_AGE=28800

# Usuarios con acceso. Formato: usuario:contraseña separados por coma.
# Contraseña en texto plano (dev) o hash bcrypt (producción).
# Generar hash bcrypt: python -c "import bcrypt; print(bcrypt.hashpw(b'tu_password', bcrypt.gensalt()).decode())"
AUTH_USERS=admin:password123,maria:password456

# IPs permitidas. Vacío = sin restricción (desarrollo local).
# Desarrollo: IP_WHITELIST=127.0.0.1
# Producción: IP_WHITELIST=203.0.113.42  o rango CIDR: 203.0.113.0/24
IP_WHITELIST=
